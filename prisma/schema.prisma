generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["feedbackiq"]
}

enum UserRole {
  owner
  admin
  member

  @@schema("feedbackiq")
}

enum FeedbackStatus {
  new
  reviewing
  generating
  pr_created
  closed

  @@schema("feedbackiq")
}

enum PullRequestStatus {
  pending
  open
  merged
  closed
  failed
  canceled

  @@schema("feedbackiq")
}

enum FeedbackPriority {
  low
  medium
  high
  urgent

  @@schema("feedbackiq")
}

model Company {
  id                    String    @id @default(uuid())
  name                  String
  githubInstallationId  Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  users    User[]
  projects Project[]

  @@schema("feedbackiq")
}

model User {
  id        String   @id @default(uuid())
  companyId String
  email     String   @unique
  name      String?
  clerkId   String   @unique
  role      UserRole @default(member)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@schema("feedbackiq")
}

model Project {
  id                String    @id @default(uuid())
  companyId         String
  name              String
  githubRepo        String
  defaultBranch     String    @default("main")
  autoGeneratePrs   Boolean   @default(false)
  publicRoadmap     Boolean   @default(false)
  publicChangelog   Boolean   @default(false)
  changelogAutoPublish Boolean @default(true)
  publicSlug        String?   @unique
  siteKey           String    @unique @default(uuid())
  websiteUrl        String?
  themePrimary      String?
  themeBackground   String?
  themeForeground   String?
  themeFontFamily   String?
  themeBorderRadius String?
  themeUpdatedAt    DateTime?
  widgetPosition         String    @default("bottom-right")
  widgetLabel            String?
  widgetSize             String    @default("default")
  widgetIcon             String    @default("chat")
  widgetHeaderTitle      String?
  widgetHeaderSubtitle   String?
  widgetContentPlaceholder String?
  widgetEmailPlaceholder String?
  widgetAttachText       String?
  widgetSubmitText       String?
  widgetSuccessMessage   String?
  widgetShowEmail        Boolean   @default(true)
  widgetRequireEmail     Boolean   @default(false)
  widgetShowScreenshot   Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company   Company            @relation(fields: [companyId], references: [id])
  feedback  Feedback[]
  changelog ChangelogEntry[]

  @@schema("feedbackiq")
}

enum ChangelogStatus {
  draft
  published

  @@schema("feedbackiq")
}

model ChangelogEntry {
  id            String          @id @default(uuid())
  projectId     String
  feedbackId    String?
  pullRequestId String?
  title         String
  body          String
  prUrl         String?
  status        ChangelogStatus @default(draft)
  publishedAt   DateTime        @default(now())
  notifiedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status, publishedAt])
  @@schema("feedbackiq")
}

model Feedback {
  id             String            @id @default(uuid())
  projectId      String
  content        String
  submitterEmail String?
  sourceUrl      String?
  status         FeedbackStatus    @default(new)
  tags           String[]          @default([])
  priority       FeedbackPriority?
  category       String?
  screenshotUrl  String?
  pageTitle      String?
  userAgent      String?
  isPublic       Boolean           @default(true)
  upvoteCount    Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  project      Project          @relation(fields: [projectId], references: [id])
  pullRequests PullRequest[]
  upvotes      FeedbackUpvote[]

  @@index([projectId, status])
  @@schema("feedbackiq")
}

model FeedbackUpvote {
  id         String   @id @default(uuid())
  feedbackId String
  voterHash  String
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@unique([feedbackId, voterHash])
  @@schema("feedbackiq")
}

model PullRequest {
  id              String            @id @default(uuid())
  feedbackId      String
  githubPrUrl     String?
  githubPrNumber  Int?
  branchName      String
  status          PullRequestStatus @default(pending)
  agentLog        String?
  workflowRunId   BigInt?
  workflowRunUrl  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  feedback Feedback @relation(fields: [feedbackId], references: [id])

  @@schema("feedbackiq")
}
